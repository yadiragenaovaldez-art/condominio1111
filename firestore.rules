rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Acceso global completo de lectura y escritura para asegurar que cualquier usuario
    // (de grupo, anónimo, o registrado) pueda sincronizar y crear grupos sin ningún tipo de restricción.
    match /{document=**} {
      allow read, write: if true;
    }
  }
}
